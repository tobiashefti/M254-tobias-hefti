                                  lang-independent="v0">
                  <adonis:value>Keine Änderung</adonis:value>
                  <adonis:metavalue/>
               </adonis:attribute>
               <adonis:attribute name="A_EXECUTION_TIME"
                                  type="UTC"
                                  notebook="1"
                                  sourcelang="de"
                                  novalue="0">
                  <adonis:value>480000</adonis:value>
                  <adonis:metavalue/>
               </adonis:attribute>
               <adonis:attribute name="A_RESTING_TIME"
                                  type="UTC"
                                  notebook="1"
                                  sourcelang="de"
                                  novalue="0">
                  <adonis:value>3000</adonis:value>
                  <adonis:metavalue/>
               </adonis:attribute>
               <adonis:attribute name="A_WAITING_TIME"
                                  type="UTC"
                                  notebook="1"
                                  sourcelang="de"
                                  novalue="0">
                  <adonis:value>20000</adonis:value>
                  <adonis:metavalue/>
               </adonis:attribute>
               <adonis:attribute name="DISPLAY_SYMBOLS_IF_RISKS_OR_CONTROLS"
                                  type="BOOL"
                                  notebook="1"
