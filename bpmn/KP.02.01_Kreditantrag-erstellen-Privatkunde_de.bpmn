      <userTask name="Auskünfte (Bonität) einholen"
                 id="_08506797-68d9-4125-b27c-ca3040a7b420"
                 isForCompensation="false">
         <documentation id="documentation_08506797-68d9-4125-b27c-ca3040a7b420"><![CDATA[Nach der Vorbereitung des Kreditantrags holt der Kundenberater Auskünfte für die Bonitätsprüfung ein. Dazu gehören wichtige Informationen (Höhe des Einkommens, Anstellungsverhältnis, Arbeitgeber, Wohnsitz, Einträge bei Bonitätsunternehmen, Haushaltsbuch, Vermögen, Familienstand, bestehende Kredite und Bürgschaften) zum Privatkunden anhand derer die Bonitätseinstufung durchgeführt werden kann.]]></documentation>
         <extensionElements>
            <adonis:instance>
               <adonis:attribute name="IDENTIFICATION_OF_CHANGES"
                                  type="ENUM"
                                  notebook="1"
                                  sourcelang="de"
                                  novalue="0"
                                  lang-independent="v0">
                  <adonis:value>Keine Änderung</adonis:value>
                  <adonis:metavalue/>
               </adonis:attribute>
               <adonis:attribute name="A_EXECUTION_TIME"
                                  type="UTC"
                                  notebook="1"
                                  sourcelang="de"
                                  novalue="0">
                  <adonis:value>180000</adonis:value>
                  <adonis:metavalue/>
               </adonis:attribute>
               <adonis:attribute name="A_RESTING_TIME"
                                  type="UTC"
                                  notebook="1"
                                  sourcelang="de"
                                  novalue="0">
