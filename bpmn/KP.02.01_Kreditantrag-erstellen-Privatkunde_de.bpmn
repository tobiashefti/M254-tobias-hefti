               <userTask name="Prüfung auf verbundene Kunden vornehmen"
                          id="_5c8650f4-0292-49a8-9de7-d425a915078a"
                          isForCompensation="false">
                  <documentation id="documentation_5c8650f4-0292-49a8-9de7-d425a915078a"><![CDATA[Es ist eine Prüfung vorzunehmen, ob verbundene Kunden im Sinne der Kapitaladäquanzverordnung (CRR) vorliegen.]]></documentation>
                  <extensionElements>
                     <adonis:instance>
                        <adonis:attribute name="IDENTIFICATION_OF_CHANGES"
                                           type="ENUM"
                                           notebook="1"
                                           sourcelang="de"
